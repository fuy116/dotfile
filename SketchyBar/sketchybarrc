# 初始化前景 App 圖示
FRONT_APP="$(osascript -e 'tell application "System Events" to name of first process whose frontmost is true' 2>/dev/null)"
sketchybar --trigger front_app_switched INFO="$FRONT_APP"

# 初始化音量（reload 後不會空白）
VOL="$(osascript -e 'output volume of (get volume settings)' 2>/dev/null)"
sketchybar --trigger volume_change INFO="$VOL"
